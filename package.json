{
  "name": "skillpath",
  "version": "0.0.1",
  "description": "Personal knowledge and skill-mapping",
  "author": "bremmdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bremmdev/skillpath"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:ui\" \"npm:dev:electron\"",
    "dev:ui": "vite dev --port 3000 --strictPort",
    "dev:electron": "tsc -p src/electron/tsconfig.json && wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "typecheck": "tsc -p tsconfig.json",
    "build:electron": "tsc -p src/electron/tsconfig.json",
    "generate-routes": "tsr generate",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "app:dir": "npm run build && electron-builder --dir",
    "app:build": "npm run build && electron-builder",
    "app:build:win": "npm run build && electron-builder --win",
    "seed:database": "tsx src/electron/db/seed.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@tanstack/router-plugin": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^28.1.0",
    "shadcn": "^4.12.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
